# 이 파일을 복사해 .env로 만들고 실제 값을 채운다. .env는 git에 커밋되지 않는다.
# GitHub Actions에서 실행할 때는 동일한 키를 repo Settings > Secrets and variables > Actions 에 등록한다.

# Gemini API (요약/브리핑 생성용 — Phase 3부터 필요, 기본 LLM)
GEMINI_API_KEY=

# Claude API (선택 — Gemini 품질 이슈 시 부분 교체용)
ANTHROPIC_API_KEY=

# 텔레그램 봇 (알림용 — Phase 1 후반부터 필요)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DART OpenAPI (재무제표/공시 — 무료, https://opendart.fss.or.kr 에서 발급)
DART_API_KEY=

# 한국은행 ECOS API (거시지표 — 무료, https://ecos.bok.or.kr 에서 발급)
ECOS_API_KEY=

# 관세청 무역통계 오픈API (L0 산업별 수출 지표 — 무료, data.go.kr 회원가입 후
# "관세청_품목별 수출입실적(GW)" 활용신청: https://www.data.go.kr/data/15101609/openapi.do)
CUSTOMS_API_KEY=
